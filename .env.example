# Copie para .env se quiser sobrescrever os defaults (que funcionam para
# desenvolvimento local sem nenhum ajuste). NUNCA commitar o .env.
POSTGRES_PASSWORD=postgres-local
JWT_KEY=chave-local-de-desenvolvimento-nao-usar-em-producao-64-bytes!!

# --- Comunicação (módulo 9) ---
# Provedores começam em 'log' (envio simulado, só registra). Para enviar de
# verdade, troque a flag do canal e preencha as credenciais.

# E-mail via Resend (sem domínio verificado, só onboarding@resend.dev para o
# e-mail do dono da conta).
# EMAIL_PROVEDOR=resend
# RESEND_API_KEY=coloque-sua-api-key
# RESEND_REMETENTE=TechPro <contato@seudominio.com>

# WhatsApp via Evolution API.
# WHATSAPP_PROVEDOR=evolution
# EVOLUTION_BASE_URL=https://sua-evolution.exemplo.com
# EVOLUTION_API_KEY=coloque-a-apikey-da-instancia
# EVOLUTION_INSTANCIA=nome-da-instancia
